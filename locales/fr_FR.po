msgid "Category visualizer"
msgid_plural "Category visualizers"
msgstr[0] "Visualiseur de catégories"
msgstr[1] "Visualiseurs de catégories"

msgid " — update recommended"
msgstr " — mise à jour recommandée"

msgid "(from local cache)"
msgstr "(cache local)"

msgid "(local 12-month cache)"
msgstr "(cache local 12 mois)"

msgid "(local groups cache)"
msgstr "(cache local groupes)"

msgid "1 yr"
msgstr "1 an"

msgid "12 months"
msgstr "12 mois"

msgid "2 yr"
msgstr "2 ans"

msgid "3 yr"
msgstr "3 ans"

msgid "6 mo"
msgstr "6 mois"

msgid "90d"
msgstr "90 j"

msgid "Access"
msgstr "Accès"

msgid "Access to the ITIL category visualizer"
msgstr "Accès au visualiseur des catégories ITIL"

msgid "All"
msgstr "Tout"

msgid "Branch total"
msgstr "Total branche"

msgid "Build the interface from the plugin frontend folder, then reload this page."
msgstr "Compilez l’interface depuis le dossier frontend du plugin, puis rechargez cette page."

msgid "categories"
msgstr "catégories"

msgid "Category %s"
msgstr "Catégorie %s"

msgid "Category tree and volumes per branch"
msgstr "Arbre des catégories et volumes par branche"

msgid "CategoryManager"
msgstr "CategoryManager"

msgid "CategoryManager access denied (profile or insufficient ticket read): %s"
msgstr "Accès CategoryManager refusé (profil ou droits de lecture des tickets insuffisants) : %s"

msgid "CategoryManager — GLPI visualization"
msgstr "CategoryManager — visualisation GLPI"

msgid "Collapse all"
msgstr "Tout replier"

msgid "Collapse branch: %s"
msgstr "Replier la branche : %s"

msgid "Counting for period…"
msgstr "Comptage pour la période…"

msgid "Data from %s"
msgstr "Données du %s"

msgid "Display"
msgstr "Affichage"

msgid "Display only; default order follows API load (often A→Z)."
msgstr "Affichage uniquement ; l’ordre par défaut suit le chargement API (souvent A→Z)."

msgid "Displayed month volume (↓)"
msgstr "Volume du mois affiché (↓)"

msgid "Error loading data: %s"
msgstr "Erreur lors du chargement des données : %s"

msgid "Error retrieving categories: %s"
msgstr "Erreur lors de la récupération des catégories : %s"

msgid "Exit full screen"
msgstr "Quitter le plein écran"

msgid "Exit full screen (Esc)"
msgstr "Quitter le plein écran (Échap)"

msgid "Expand branch: %s"
msgstr "Déplier la branche : %s"

msgid "Explore the category hierarchy and ticket volumes. Data is filtered by your profile and GLPI entities."
msgstr "Explorez la hiérarchie des catégories et les volumes de tickets. Les données sont filtrées selon votre profil et vos entités GLPI."

msgid "Finalizing — branch totals (including subcategories) and hierarchy levels…"
msgstr "Finalisation — totaux par branche (sous-catégories incluses) et niveaux hiérarchiques…"

msgid "Full history (same as table)"
msgstr "Historique complet (identique au tableau)"

msgid "Full screen"
msgstr "Plein écran"

msgid "Full screen chart"
msgstr "Graphique plein écran"

msgid "Groups"
msgstr "Groupes"

msgid "Groups: month %s/12 (%s)…"
msgstr "Groupes : mois %s/12 (%s)…"

msgid "Heatmap of solved or closed tickets by group and month"
msgstr "Carte de chaleur des tickets résolus ou fermés par groupe et par mois"

msgid "Heatmap: volume per branch over 12 rolling months"
msgstr "Carte de chaleur : volume par branche sur 12 mois glissants"

msgid "Hide all subcategories"
msgstr "Masquer toutes les sous-catégories"

msgid "ID"
msgstr "ID"

msgid "Independent of the table and tree (always full history). Period counters are cached with no automatic expiry; GLPI is called only when there is no local data for that period, or when you click Refresh counts. Filter on opening date (GLPI may fall back to date_creation)."
msgstr "Indépendant du tableau et de l’arbre (toujours historique complet). Les compteurs par période sont mis en cache sans expiration automatique ; GLPI n’est appelé que s’il n’y a pas encore de données locales pour cette période, ou si vous cliquez sur « Rafraîchir les compteurs ». Filtre sur la date d’ouverture (GLPI peut utiliser date_creation en secours)."

msgid "Initializing…"
msgstr "Initialisation…"

msgid "Intensity = count of solved (5) or closed (6) tickets for the month, by resolution date (solvedate) and assigned group."
msgstr "Intensité = nombre de tickets résolus (5) ou fermés (6) pour le mois, selon la date de résolution (solvedate) et le groupe assigné."

msgid "Invalid \"ids\" parameter."
msgstr "Paramètre « ids » invalide."

msgid "Invalid group_ids / start / end parameters."
msgstr "Paramètres group_ids / start / end invalides."

msgid "Invalid ids / start / end parameters."
msgstr "Paramètres ids / start / end invalides."

msgid "Invalid or expired CSRF token — reload the visualizer page."
msgstr "Jeton CSRF invalide ou expiré — rechargez la page du visualiseur."

msgid "ITIL categories"
msgstr "Catégories ITIL"

msgid "ITIL category visualization"
msgstr "Visualisation des catégories ITIL"

msgid "JSON encoding failed (categories): %s"
msgstr "Échec de l’encodage JSON (catégories) : %s"

msgid "JSON encoding failed (group_counts_range): %s"
msgstr "Échec de l’encodage JSON (group_counts_range) : %s"

msgid "JSON encoding failed (groups): %s"
msgstr "Échec de l’encodage JSON (groupes) : %s"

msgid "JSON encoding failed (ticket_counts): %s"
msgstr "Échec de l’encodage JSON (ticket_counts) : %s"

msgid "JSON encoding failed (ticket_counts_range): %s"
msgstr "Échec de l’encodage JSON (ticket_counts_range) : %s"

msgid "Level"
msgstr "Niveau"

msgid "Load failed — see error message below or console (F12)."
msgstr "Échec du chargement — voir le message d’erreur ci-dessous ou la console (F12)."

msgid "Load order (default)"
msgstr "Ordre de chargement (par défaut)"

msgid "Loading categories"
msgstr "Chargement des catégories"

msgid "Loading GLPI groups…"
msgstr "Chargement des groupes GLPI…"

msgid "Month %s/12 (%s) — %s/%s categories"
msgstr "Mois %s/12 (%s) — %s/%s catégories"

msgid "Month %s/12 (%s) — %s/%s groups"
msgstr "Mois %s/12 (%s) — %s/%s groupes"

msgid "Name"
msgstr "Nom"

msgid "Name (A→Z)"
msgstr "Nom (A→Z)"

msgid "No categories found"
msgstr "Aucune catégorie trouvée"

msgid "No category"
msgstr "Aucune catégorie"

msgid "No GLPI groups found — check API rights or user profile."
msgstr "Aucun groupe GLPI trouvé — vérifiez les droits API ou le profil utilisateur."

msgid "No name"
msgstr "Sans nom"

msgid "No solved or closed tickets by assigned group in this 12-month window (check API rights or try again later)."
msgstr "Aucun ticket résolu ou fermé par groupe assigné sur cette fenêtre de 12 mois (vérifiez les droits API ou réessayez plus tard)."

msgid "Number of categories loaded from GLPI"
msgstr "Nombre de catégories chargées depuis GLPI"

msgid "Number of tickets solved or closed (GLPI statuses 5 and 6) per assigned group over the last 12 rolling months (sliding window). Resolution date (solvedate). Only groups with at least one ticket in the period appear."
msgstr "Nombre de tickets résolus ou fermés (statuts GLPI 5 et 6) par groupe assigné sur les 12 derniers mois glissants (fenêtre coulissante). Date de résolution (solvedate). Seuls les groupes ayant au moins un ticket sur la période apparaissent."

msgid "Open tickets on this category only (excluding subcategories)"
msgstr "Tickets ouverts sur cette catégorie uniquement (hors sous-catégories)"

msgid "Order of business roots follows the sort; under each expanded root, GLPI tree order. Display only (does not change GLPI)."
msgstr "L’ordre des racines métier suit le tri ; sous chaque racine dépliée, ordre de l’arbre GLPI. Affichage uniquement (ne modifie pas GLPI)."

msgid "Parent category"
msgstr "Catégorie parente"

msgid "Period (Sunburst only)"
msgstr "Période (Sunburst uniquement)"

msgid "POST method expected."
msgstr "Méthode POST attendue."

msgid "Preparing load (GLPI session, then category list)…"
msgstr "Préparation du chargement (session GLPI, puis liste des catégories)…"

msgid "Preparing monthly ranges…"
msgstr "Préparation des plages mensuelles…"

msgid "Production files missing"
msgstr "Fichiers de production absents"

msgid "Proportional to tickets per branch."
msgstr "Proportionnel au nombre de tickets par branche."

msgid "Raw category data (debug)"
msgstr "Données brutes des catégories (débogage)"

msgid "Re-run all GLPI count requests for this period"
msgstr "Relancer toutes les requêtes GLPI de comptage pour cette période"

msgid "Refresh"
msgstr "Actualiser"

msgid "Refresh 12 months"
msgstr "Rafraîchir les 12 mois"

msgid "Refresh counts"
msgstr "Rafraîchir les compteurs"

msgid "Refresh failed: %s"
msgstr "Actualisation impossible : %s"

msgid "Refresh groups"
msgstr "Rafraîchir les groupes"

msgid "Refreshing data from GLPI…"
msgstr "Actualisation des données depuis GLPI…"

msgid "Reload all requests (12 months × categories)"
msgstr "Recharger toutes les requêtes (12 mois × catégories)"

msgid "Reload group list and all counts (12 months × groups)"
msgstr "Recharger la liste des groupes et tous les comptages (12 mois × groupes)"

msgid "Retry"
msgstr "Réessayer"

msgid "Rolling 1-year window"
msgstr "Fenêtre glissante d’un an"

msgid "Rolling 2-year window"
msgstr "Fenêtre glissante de deux ans"

msgid "Rolling 3-year window"
msgstr "Fenêtre glissante de trois ans"

msgid "Rolling 6-month window"
msgstr "Fenêtre glissante de 6 mois"

msgid "Rolling 90-day window"
msgstr "Fenêtre glissante de 90 jours"

msgid "Run `npm run build` in plugins/categorymanager/frontend"
msgstr "Exécutez « npm run build » dans plugins/categorymanager/frontend"

msgid "Search for a category…"
msgstr "Rechercher une catégorie…"

msgid "Sectors by hierarchy only (angles tied to leaves), without weighting by ticket volume."
msgstr "Secteurs selon la hiérarchie uniquement (angles liés aux feuilles), sans pondération par volume de tickets."

msgid "Sectors proportional to ticket count per branch (total including subcategories)."
msgstr "Secteurs proportionnels au nombre de tickets par branche (total incluant les sous-catégories)."

msgid "Server error: %s"
msgstr "Erreur serveur : %s"

msgid "Session expired — log in to GLPI again and reload the visualizer."
msgstr "Session expirée — reconnectez-vous à GLPI puis rechargez le visualiseur."

msgid "Showing data from %s"
msgstr "Données affichées depuis %s"

msgid "Showing the first 5 categories only"
msgstr "Affichage des 5 premières catégories uniquement"

msgid "Sort rows"
msgstr "Trier les lignes"

msgid "Step 1/3 — Connecting to GLPI API and retrieving ITIL categories…"
msgstr "Étape 1/3 — Connexion à l’API GLPI et récupération de la liste des catégories ITIL…"

msgid "Step 2/3 — %s categories received. Preparing ticket counts…"
msgstr "Étape 2/3 — %s catégories reçues. Préparation des compteurs de tickets…"

msgid "Step 3/3 — Counting tickets (full history for table/tree): preparing search/Ticket requests (0 / %s)…"
msgstr "Étape 3/3 — Comptage des tickets (historique complet pour tableau / arbre) : préparation des requêtes search/Ticket (0 / %s)…"

msgid "Step 3/3 — Counting tickets: %s / %s categories processed (batched requests to GLPI)…"
msgstr "Étape 3/3 — Comptage des tickets : %s / %s catégories traitées (requêtes par lots vers GLPI)…"

msgid "Structure"
msgstr "Structure"

msgid "Structure view (hierarchical angles)."
msgstr "Vue structure (angles hiérarchiques)."

msgid "Sum: direct tickets + tickets on all subcategories (same logic as Sunburst “Tickets”)"
msgstr "Somme : tickets directs + tickets sur toutes les sous-catégories (même logique que Sunburst « Tickets »)"

msgid "Sunburst"
msgstr "Sunburst"

msgid "Sunburst display mode"
msgstr "Mode d’affichage Sunburst"

msgid "Switch to dark mode"
msgstr "Passer en mode sombre"

msgid "Switch to light mode"
msgstr "Passer en mode clair"

msgid "Table"
msgstr "Tableau"

msgid "Temporal heatmap: month %s/12 (%s)…"
msgstr "Carte temporelle : mois %s/12 (%s)…"

msgid "This plugin requires GLPI >= 11.0."
msgstr "Ce plugin nécessite GLPI ≥ 11.0."

msgid "Ticket volume per branch (category + sub-trees) over the last 12 rolling months (window up to today). Use ▶ / ▼ to show subcategories under each business root. The date used is the ticket opening date (GLPI field detected: date or date_creation)."
msgstr "Volume de tickets par branche (catégorie + sous-arbres) sur les 12 derniers mois glissants (fenêtre jusqu’à aujourd’hui). Utilisez ▶ / ▼ pour afficher les sous-catégories sous chaque racine métier. La date utilisée est la date d’ouverture du ticket (champ GLPI détecté : date ou date_creation)."

msgid "Tickets"
msgstr "Tickets"

msgid "Tickets (direct)"
msgstr "Tickets (directs)"

msgid "Tickets solved or closed per assigned group over 12 rolling months"
msgstr "Tickets résolus ou fermés par groupe assigné sur 12 mois glissants"

msgid "Total volume over 12 months (↓)"
msgstr "Volume total sur 12 mois (↓)"

msgid "Tree"
msgstr "Arbre"

msgid "Tree order (business roots)"
msgstr "Ordre de l’arbre (racines métier)"

msgid "Unable to count for this period."
msgstr "Comptage impossible pour cette période."

msgid "Unable to load group heatmap (check API rights / Ticket fields)."
msgstr "Impossible de charger la heatmap par groupes (vérifiez les droits API / les champs Ticket)."

msgid "Unable to load temporal heatmap (check API rights / Ticket date field)."
msgstr "Impossible de charger la carte temporelle (vérifiez les droits API / le champ date Ticket)."

msgid "Unknown action."
msgstr "Action inconnue."

msgid "Unknown error"
msgstr "Erreur inconnue"

msgid "Unknown parent (%s)"
msgstr "Parent inconnu (%s)"

msgid "View type"
msgstr "Type de vue"
